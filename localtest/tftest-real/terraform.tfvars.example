# Fill in your real ManifestIT credentials before running
# DO NOT commit this file to git (it contains sensitive values)

manifestit_api_key            = "YOUR_API_KEY_HERE"
manifestit_api_url            = "https://api.manifestit.io"   # or your self-hosted URL
manifestit_org_id             = 1                              # your org ID
manifestit_org_key            = "your-org-key"
manifestit_provider_id        = 1
manifestit_provider_config_id = 1
tracked_branch                = "main"
tracked_repo                  = "https://github.com/your-org/your-repo.git"

